{
  "name": "repo-expert",
  "version": "1.0.0",
  "description": "Persistent local-first AI memory agents for your git repositories — sqlite-vec + any OpenAI-compatible LLM, exposed via CLI and MCP",
  "bin": {
    "repo-expert": "./dist/bin/cli.mjs",
    "repo-expert-mcp": "./dist/bin/mcp-server.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "config.example.yaml",
    "docs/mcp-setup.md",
    "docs/architecture.md",
    "vendor/wasm"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "build:sea": "pnpm build && bash scripts/build-sea.sh",
    "prepublishOnly": "pnpm build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "lint": "eslint . --max-warnings 0 --report-unused-disable-directives",
    "lint:all": "eslint . --max-warnings 0 --report-unused-disable-directives",
    "lint:fix": "eslint . --fix",
    "lint:spikes": "eslint spikes --max-warnings 0 --report-unused-disable-directives",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "typecheck:strict": "pnpm run typecheck",
    "typecheck:exact": "pnpm run typecheck",
    "typecheck:index-signature": "pnpm run typecheck",
    "typecheck:side-effect-imports": "pnpm run typecheck",
    "typecheck:unused": "pnpm run typecheck",
    "sanity": "pnpm run lint && pnpm run typecheck && pnpm test -- --runInBand",
    "test": "vitest run",
    "bench": "tsx eval/bench.ts",
    "repo-expert": "tsx src/cli.ts",
    "mcp-server": "tsx src/mcp-server.ts",
    "test:mutation": "stryker run"
  },
  "keywords": [
    "mcp",
    "llm",
    "rag",
    "codebase",
    "memory",
    "agent",
    "ollama",
    "local-first",
    "sqlite-vec",
    "tree-sitter"
  ],
  "author": "Pedro Guimarães",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0x7067/agent-as-repo.git"
  },
  "homepage": "https://github.com/0x7067/agent-as-repo#readme",
  "bugs": {
    "url": "https://github.com/0x7067/agent-as-repo/issues"
  },
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=22 <23"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "fast-glob": "^3.3.3",
    "js-yaml": "^4.3.0",
    "p-limit": "^7.3.0",
    "sqlite-vec": "^0.1.9",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-c-sharp": "^0.23.5",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.6.0",
    "@eslint/js": "^10.0.1",
    "@lumis-sh/wasm-kotlin": "^0.26.3",
    "@lumis-sh/wasm-swift": "^0.26.1",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.3",
    "@vitest/eslint-plugin": "^1.6.20",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-de-morgan": "^2.0.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-only-error": "^1.0.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.3.0",
    "postject": "^1.0.0-alpha.6",
    "tree-sitter-cli": "^0.26.10",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-swift": "^0.7.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.1.9"
  }
}
