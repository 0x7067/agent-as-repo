{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts",
    "vitest.config.ts",
    "vitest.stryker.config.ts",
    "vitest.stryker.shell.config.ts"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/__test__/**",
    "spikes",
    "node_modules",
    "dist"
  ]
}